                "[Phenology].AccumulatedTT as AccTT",
                "[Leaf].LAI as LAI",
                "[Leaf].Wt as LeafWt",
                "[Crown].Wt as CrownWt",
                "[Root].Wt as RootWt",
                "[Fruit].Wt as FruitWt",
                "[Crown].Live.StorageWt as CrownStorageWt",
