                      ],
                      "Enabled": true,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.PMF.Phen.GotoPhase, Models",
                      "Start": "Harvest",
                      "IsEmerged": true,
                      "PhaseNameToGoto": "VegetativeGrowth to FlowerInduction",
                      "RemovalType": 5,
                      "Name": "RepeatFlowering",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.Functions.Constant, Models",
                      "FixedValue": 1.0,
                      "Units": null,
                      "Name": "PhotoperiodGateValue",
