            {
              "$type": "Models.PMF.Plant, Models",
              "PlantType": "Strawberry",
              "Name": "Strawberry",
              "ResourceName": "",
              "Children": [
                {
                  "$type": "Models.PMF.Phen.Phenology, Models",
                  "Name": "Phenology",
                  "ResourceName": null,
                  "Children": [
                    {
                      "$type": "Models.Functions.MultiplyFunction, Models",
                      "Name": "BaseThermalTime",
                      "ResourceName": null,
                      "Children": [
                        {
                          "$type": "Models.Functions.SubDailyInterpolation, Models",
                          "agregationMethod": 0,
                          "Name": "SubDailyTT",
                          "ResourceName": null,
                          "Children": [
                            {
                              "$type": "Models.Functions.IndexedExpressionFunction, Models",
                              "Expression": "(min(max(((2 * (max(InterpT - Alpha.TMin, 0) ^ Alpha) * ((Alpha.TOpt - Alpha.TMin) ^ Alpha) - max(InterpT - Alpha.TMin, 0) ^ (2 * Alpha)) / ((Alpha.TOpt - Alpha.TMin) ^ (2 * Alpha))), 0), 1) ^ Beta) * (Alpha.TOpt - Alpha.TMin)",
                              "IndexVariable": "InterpT",
                              "Name": "Response",
                              "ResourceName": null,
                              "Children": [
                                {
                                  "$type": "Models.Functions.ExpressionFunction, Models",
                                  "Units": null,
                                  "Expression": "divide(ln(2), ln(divide(TMax - TMin, TOpt - TMin)))",
                                  "Name": "Alpha",
                                  "ResourceName": null,
                                  "Children": [
                                    {
                                      "$type": "Models.Functions.Constant, Models",
                                      "FixedValue": 5.0,
                                      "Units": null,
                                      "Name": "TMin",
                                      "ResourceName": null,
                                      "Children": [],
                                      "Enabled": true,
                                      "ReadOnly": false
                                    },
                                    {
                                      "$type": "Models.Functions.Constant, Models",
                                      "FixedValue": 20.0,
                                      "Units": null,
                                      "Name": "TOpt",
                                      "ResourceName": null,
                                      "Children": [],
                                      "Enabled": true,
                                      "ReadOnly": false
                                    },
                                    {
                                      "$type": "Models.Functions.Constant, Models",
                                      "FixedValue": 30.0,
                                      "Units": null,
                                      "Name": "TMax",
                                      "ResourceName": null,
                                      "Children": [],
                                      "Enabled": true,
                                      "ReadOnly": false
                                    }
                                  ],
                                  "Enabled": true,
                                  "ReadOnly": false
                                },
                                {
                                  "$type": "Models.Functions.Constant, Models",
                                  "FixedValue": 1.0,
                                  "Units": null,
                                  "Name": "Beta",
                                  "ResourceName": null,
                                  "Children": [],
                                  "Enabled": true,
                                  "ReadOnly": false
                                }
                              ],
                              "Enabled": true,
                              "ReadOnly": false
