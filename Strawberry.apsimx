                                      "FixedValue": 20.0,
                                      "Units": null,
                                      "Name": "TOpt",
                                      "ResourceName": null,
                                      "Children": [],
                                      "Enabled": true,
                                      "ReadOnly": false
                                    },
                                    {
                                      "$type": "Models.Functions.Constant, Models",
                                      "FixedValue": 30.0,
                                      "Units": null,
                                      "Name": "TMax",
                                      "ResourceName": null,
                                      "Children": [],
                                      "Enabled": true,
